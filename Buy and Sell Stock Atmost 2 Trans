class Solution:
	# @param A : tuple of integers
	# @return an integer
	def maxProfit(self, A):
        if not A:
            return 0
        firstbuy, firstsell, secondbuy, secondsell = -A[0],0,float("-inf"),0
        for i in range(1,len(A)):
            b1,s1,b2,s2 = firstbuy,firstsell,secondbuy,secondsell
            firstbuy = max(b1,-A[i])
            firstsell=max(s1,b1+A[i])
            secondbuy = max(b2,s1-A[i])
            secondsell=max(s2,b2+A[i])
        return max(firstsell,secondsell)
