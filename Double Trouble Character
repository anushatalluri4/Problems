class Solution:
    # @param A : string
    # @return a strings
    def solve(self, A):
        stack = []
        for i in range(len(A)):
            if stack and stack[-1]==A[i]:
                stack.pop()
            else:
                stack.append(A[i])
        s=""
        while stack:
            s+=stack.pop()
        return s[::-1]
