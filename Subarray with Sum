class Solution:
    # @param A : list of integers
    # @param B : integer
    # @return a list of integers
    def solve(self, A, B):
        l, r = 0, 0
        sum = 0
        while r<len(A):
            sum += A[r]
            while sum>B and l<=r:
                sum -= A[l]
                l+=1
            if sum==B:
                return A[l:r+1]
            
            r+=1
        return [-1]
