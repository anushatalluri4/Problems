class Solution:
	# @param A : list of integers
	# @return an integer
	def candy(self, A):
        left, right = [1]*len(A),[1]*len(A)
        left[0] = 1
        for i in range(1,len(A)):
            if A[i]>A[i-1]:
                left[i] = left[i-1]+1
        right[len(A)-1]=1
        for i in range(len(A)-2,-1,-1):
            if A[i]>A[i+1]:
                right[i] = right[i+1]+1
        ans = 0
        for i in range(len(A)):
            ans+=max(left[i],right[i])
        return ans

